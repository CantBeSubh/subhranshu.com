generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Counter {
  id         Int @id @default(autoincrement())
  likeCount  Int @default(0) @map("like_count")
  visitCount Int @default(0) @map("visit_count")
}
